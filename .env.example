# Local development environment template.
# Copy this to .env and fill in the secret values on your own machine.

# OpenAI settings used by POST /api/search.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=25000

# Google Apps Script Web App URL used by account signup/login.
GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Local server settings. Render provides PORT automatically in production.
PORT=4175
HOST=0.0.0.0
ALLOWED_ORIGIN=
