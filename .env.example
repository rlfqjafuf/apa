# Local development environment template.
# Copy this to .env and fill in the secret values on your own machine.

# OpenAI settings used by POST /api/search.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CLASSIFIER_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=45000

# Optional: read OPENAI_API_KEY from Google Sheets through Apps Script.
# The Apps Script must return the value from the "키" sheet A2 cell.
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_SECRET=
OPENAI_KEY_CACHE_MS=300000

# Local server settings. Render provides PORT automatically in production.
PORT=4175
HOST=0.0.0.0
ALLOWED_ORIGIN=
