# Local development environment template.
# Copy this to .env and fill in the secret values on your own machine.

# OpenAI settings used by POST /api/search.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=25000

# Local server settings. Render provides PORT automatically in production.
PORT=4175
HOST=0.0.0.0
ALLOWED_ORIGIN=

# Public Firebase web app settings used by the browser SDK.
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=
